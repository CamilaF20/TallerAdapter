{
  "compilerOptions": {
    /* Compilación */
    "target": "ES2020",
    "module": "commonjs",

    /* Estructura del proyecto */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Interoperabilidad */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Calidad de código */
    "strict": true,

    /* Optimización */
    "skipLibCheck": true
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}